{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "main-capability",
    "description": "Capability for the main window",
    "windows": ["launcher", "app-*"],
    "permissions": [
      "path:default",
      
      "event:default",
      
      "window:default",
      
      "app:default",
      
      "resources:default",
      
      "menu:default",
      
      "tray:default",
      
      "window:allow-set-title",
      
      "dialog:allow-open",
      "dialog:allow-save",

      "fs:allow-read",
      "fs:allow-exists"
    ]
  }