{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "*"
  ],
  "permissions": [
    "path:default",
    "event:default",
    "window:default",
    "resources:default",
    "menu:default",
    "tray:default",

    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
   
    {
      "identifier": "fs:scope",
      "allow": [
        "**"
      ]
    },
    "shell:allow-open",

    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",

    "app:allow-app-show",
    "app:allow-app-hide",
    "app:allow-version"
  ]
}